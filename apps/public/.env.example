VITE_API_URL=http://localhost:4000/api

# Con el dev server en localhost, la API usa este host para cargar el tenant (sitio).
VITE_SITE_HOST=paolamendozanails.quicklyecsites.com

# Opcional: origen para las URLs de Payphone (responseUrl / cancellationUrl).
# Por defecto se usa el origen del navegador (p. ej. http://localhost:5176).
# Si en Payphone Developer registraste otro dominio, ese dominio debe coincidir con esta URL:
# usa el mismo host en el navegador (p. ej. /etc/hosts → tenant.local:5176) y pon aquí ese origen.
# VITE_PUBLIC_APP_ORIGIN=http://localhost:5176
