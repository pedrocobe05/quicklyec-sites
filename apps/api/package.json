{
  "name": "@quickly-sites/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "npm run start:dev",
    "dev:ts-node": "ts-node -r tsconfig-paths/register src/main.ts",
    "prebuild": "npm run build -w @quickly-sites/shared",
    "build": "rm -rf dist && nest build",
    "start": "node dist/main.js",
    "prestart:dev": "npm run build -w @quickly-sites/shared",
    "start:dev": "node --watch --watch-path ./src --watch-path ../../packages/shared/src -r ts-node/register -r tsconfig-paths/register ./src/main.ts",
    "prestart:debug": "npm run build -w @quickly-sites/shared",
    "start:debug": "node --watch --watch-path ./src --watch-path ../../packages/shared/src --inspect -r ts-node/register -r tsconfig-paths/register ./src/main.ts",
    "lint": "eslint src --ext .ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/common/database/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "@quickly-sites/shared": "0.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.17.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
