PORT=4000
API_PREFIX=api
APP_ENV=development

# WhatsApp Cloud API (Meta): mismo valor que "Verify token" en el webhook del panel de desarrolladores
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Token de acceso (System User o temporal) y Phone number ID del número de la API (WhatsApp > API de la nube)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Opcional, por defecto v22.0
# WHATSAPP_GRAPH_API_VERSION=v22.0

# Nombres de plantilla Meta (deben coincidir con los aprobados por idioma)
WHATSAPP_REMINDER_TEMPLATE_NAME_ES=recordatorio_cita
WHATSAPP_REMINDER_TEMPLATE_NAME_EN=recordatorio_cita_en
# Códigos de idioma aprobados en Meta para cada plantilla (ej. es_EC, es_MX, en_US)
WHATSAPP_REMINDER_LANGUAGE_CODE_ES=es_EC
WHATSAPP_REMINDER_LANGUAGE_CODE_EN=en_US

# Si es true, las respuestas de error de Payphone (prepare/confirm) incluyen en JSON el cuerpo bruto
# y el JSON parseado. No activar en producción (puede exponer detalles internos).
PAYPHONE_EXPOSE_RAW_RESPONSE=false

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
DB_HOST=localhost
DB_PORT=4533
DB_NAME=quicklysites
DB_USER=postgres
DB_PASSWORD=2412
DB_SSL=false
PUBLIC_ADMIN_URL=http://localhost:5173
PUBLIC_SITE_URL=http://localhost:5174
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Quickly Sites
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_REGION=auto
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
R2_PRESIGN_TTL_SECONDS=900
R2_FORCE_PATH_STYLE=false
